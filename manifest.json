{
  "manifest_version": 3,
  "name": "Dynamics Notifications",
  "version": "1.5",
  "description": "Aggressive alerts for incoming calls in Dynamics 365 Omnichannel — never miss a call again",
  "permissions": ["notifications", "storage", "offscreen", "idle"],
  "host_permissions": ["*://*.dynamics.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.dynamics.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
